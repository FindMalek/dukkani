# =============================================================================
# DUKKANI MONOREPO - ENVIRONMENT VARIABLES
# =============================================================================
# Copy this file to .env and fill in your values
# This is the single source of truth for all environment variables
# =============================================================================

# -----------------------------------------------------------------------------
# MIGRATIONS
# -----------------------------------------------------------------------------
# Supabase source configuration (for migrations)
SUPABASE_URL="https://your-project.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"
SUPABASE_STORAGE_BUCKET="production"

# Migration configuration
MIGRATION_BATCH_SIZE=5
MIGRATION_DRY_RUN=false
MIGRATION_VALIDATE_AFTER=true
MIGRATION_CLEANUP_SOURCE=false
MIGRATION_SCOPE="db-referenced"
MIGRATION_ROLLBACK_ENABLED=true

# -----------------------------------------------------------------------------
# DATABASE
# -----------------------------------------------------------------------------
# PostgreSQL connection string
# Required by: DB package, API app
DATABASE_URL="postgresql://postgres:password@localhost:5432/dukkani"

# -----------------------------------------------------------------------------
# BASE CONFIGURATION
# -----------------------------------------------------------------------------
# Node environment (development, production, local)
# Default: "local"
NEXT_PUBLIC_NODE_ENV="local"

# CORS origin - Base URL for API requests
# Required by: All apps
NEXT_PUBLIC_API_URL="http://localhost:3002"

# Allowed origin pattern for CORS validation
# Can be "*", a URL, or wildcard pattern like "*.domain.com"
# Required by: All apps
NEXT_PUBLIC_ALLOWED_ORIGIN="*"

# CORS preview origin pattern
# Required by: All apps
CORS_PREVIEW_ORIGIN_PATTERN="*.preview.dukkani.co"

# Telegram bot name
# Required by: All apps (base)
TELEGRAM_BOT_NAME="your_bot_name"

# -----------------------------------------------------------------------------
# APPLICATION URLS
# -----------------------------------------------------------------------------
# Web app URL
# Required by: Web app, Dashboard app, Storefront app
NEXT_PUBLIC_WEB_URL="http://localhost:3000"

# Dashboard app URL
# Required by: Dashboard app, Web app, Storefront app
NEXT_PUBLIC_DASHBOARD_URL="http://localhost:3003"

# Store domain (e.g., "example.com" or "localhost:3000")
# Required by: Storefront app, API app
NEXT_PUBLIC_STORE_DOMAIN="localhost:3004"

# -----------------------------------------------------------------------------
# AUTHENTICATION
# -----------------------------------------------------------------------------
# Better Auth secret key (generate with: openssl rand -base64 32)
# Required by: Auth package
BETTER_AUTH_SECRET="your-secret-key-here-generate-with-openssl"

# Google OAuth
# Required by: Auth package
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Facebook OAuth
# Required by: Auth package
FACEBOOK_CLIENT_ID=""
FACEBOOK_CLIENT_SECRET=""

# Apple OAuth
# Required by: Auth package
APPLE_CLIENT_ID=""
APPLE_CLIENT_SECRET=""

# -----------------------------------------------------------------------------
# TELEGRAM BOT API
# -----------------------------------------------------------------------------
# Telegram Bot API token (get from @BotFather)
# Required by: API app
TELEGRAM_API_TOKEN=""

# Telegram webhook secret for verifying webhook requests
# Required by: API app
TELEGRAM_WEBHOOK_SECRET=""

# -----------------------------------------------------------------------------
# STORAGE (S3-compatible: MinIO local / Cloudflare R2 production)
# -----------------------------------------------------------------------------
# S3 API endpoint
# Local (MinIO): http://localhost:9000
# Production (R2): https://<ACCOUNT_ID>.r2.cloudflarestorage.com (EU: ...eu.r2.cloudflarestorage.com)
S3_ENDPOINT="http://localhost:9000"

# S3 credentials (keep secret!)
# Local (MinIO): minioadmin / minioadmin
# Production (R2): Create API token in Cloudflare R2 dashboard
S3_ACCESS_KEY_ID="minioadmin"
S3_SECRET_ACCESS_KEY="minioadmin"

# Bucket name
S3_BUCKET="dukkani"

# Public URL for object access (no trailing slash)
# Local (MinIO): http://localhost:9000/dukkani
# Production (R2): Enable public bucket in Cloudflare dashboard for URL
S3_PUBLIC_BASE_URL="http://localhost:9000/dukkani"

# Region: "auto" for R2, "us-east-1" for MinIO
S3_REGION="us-east-1"

# Maximum file size in bytes (default: 5MB)
STORAGE_MAX_FILE_SIZE="5242880"

# Allowed MIME types (comma-separated or wildcard like "image/*")
STORAGE_ALLOWED_MIME_TYPES="image/*"

# -----------------------------------------------------------------------------
# OBSERVABILITY (OPENTELEMETRY)
# -----------------------------------------------------------------------------
# Service name for tracing
# Required by: All apps
OTEL_SERVICE_NAME="dukkani"

# Sampling rate (0.0 to 1.0, where 1.0 = 100% of traces)
# Required by: All apps
OTEL_SAMPLING_RATE="1"

# Enable/disable OpenTelemetry
# Required by: All apps
OTEL_ENABLED="false"

# OTLP exporter endpoint (base URL)
# Required by: All apps
OTEL_EXPORTER_OTLP_ENDPOINT=""

# OTLP traces endpoint (optional, overrides base endpoint)
OTEL_EXPORTER_OTLP_TRACES_ENDPOINT=""

# OTLP metrics endpoint (optional, overrides base endpoint)
OTEL_EXPORTER_OTLP_METRICS_ENDPOINT=""

# OTLP logs endpoint (optional, overrides base endpoint)
OTEL_EXPORTER_OTLP_LOGS_ENDPOINT=""

# OTLP headers (optional, JSON string or key=value pairs)
OTEL_EXPORTER_OTLP_HEADERS=""

# OTLP protocol (optional)
# Default: "http/protobuf"
OTEL_EXPORTER_OTLP_PROTOCOL="http/protobuf"

# OTLP compression (optional)
# Default: "gzip"
OTEL_EXPORTER_OTLP_COMPRESSION="gzip"

# Better Stack API key for logging (optional)
# Required by: All apps (optional)
BETTER_STACK_API_KEY=""

# -----------------------------------------------------------------------------
# VERCEL (AUTO-INJECTED IN VERCEL DEPLOYMENTS)
# -----------------------------------------------------------------------------
# These are automatically set by Vercel - no need to configure locally
VERCEL_BRANCH_URL=""
VERCEL_PROJECT_PRODUCTION_URL=""
VERCEL_REGION=""
VERCEL_DEPLOYMENT_ID=""
VERCEL_PROJECT_ID=""
VERCEL=""