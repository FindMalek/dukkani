## Providers

**Location:** `apps/dashboard/src/components/layout/providers.tsx`

Create the QueryClient per-render — never import it as a module singleton. The `onError` callback wires up the global toast for all query errors.

```typescript
"use client";

import { useState } from "react";
import { QueryClientProvider } from "@tanstack/react-query";
import { makeQueryClient } from "@/shared/api/orpc";
import { toast } from "sonner";

export default function Providers({ children }) {
  // Per-render client prevents cross-request state leaks in SSR
  const [queryClient] = useState(() =>
    makeQueryClient((error) =>
      toast.error(`Error: ${error.message}`, {
        action: { label: "retry", onClick: () => queryClient.invalidateQueries() },
      })
    )
  );
  return (
    <QueryClientProvider client={queryClient}>{children}</QueryClientProvider>
  );
}
```

## Route Groups

### (auth) Route Group

Public authentication routes.

**Location**: `apps/dashboard/src/app/[lang]/(auth)/`

**Routes**: `/login`, `/onboarding`

### (dashboard) Route Group

Protected dashboard routes. Layout prefetches critical data server-side.

**Location**: `apps/dashboard/src/app/[lang]/(dashboard)/`

**Pattern**:
```typescript
export default async function DashboardLayout({ children }) {
  const session = await getServerSession();
  if (!session?.user) { /* redirect or AuthGuard */ }

  const queryClient = getServerQueryClient();
  await Promise.all([
    queryClient.prefetchQuery(appQueries.account.currentUser()),
    queryClient.prefetchQuery(appQueries.store.all()),
  ]);

  return (
    <HydrationBoundary state={dehydrate(queryClient)}>
      <DashboardLayoutContent>{children}</DashboardLayoutContent>
    </HydrationBoundary>
  );
}
```

