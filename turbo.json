{
  "$schema": "https://turbo.build/schema.json",
  "ui": "tui",
  "tasks": {
    "build": {
      "dependsOn": ["^build", "db:generate"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": ["dist/**", ".next/**", "!.next/cache/**"],
      "env": [
        "DATABASE_URL",
        "BETTER_AUTH_SECRET",
        "GOOGLE_CLIENT_ID",
        "GOOGLE_CLIENT_SECRET",
        "FACEBOOK_CLIENT_ID",
        "FACEBOOK_CLIENT_SECRET",
        "S3_ENDPOINT",
        "S3_ACCESS_KEY_ID",
        "S3_SECRET_ACCESS_KEY",
        "S3_BUCKET",
        "S3_PUBLIC_BASE_URL",
        "STORAGE_MAX_FILE_SIZE",
        "STORAGE_ALLOWED_MIME_TYPES",
        "APPLE_CLIENT_ID",
        "APPLE_CLIENT_SECRET",
        "TELEGRAM_BOT_NAME",
        "TELEGRAM_API_TOKEN",
        "TELEGRAM_WEBHOOK_SECRET",
        "NEXT_PUBLIC_API_URL",
        "NEXT_PUBLIC_ALLOWED_ORIGIN",
        "OTEL_SERVICE_NAME",
        "OTEL_SAMPLING_RATE"
      ]
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "check-types": {
      "dependsOn": ["^check-types"]
    },
    "check-types:fast": {
      "dependsOn": ["^check-types:fast"]
    },
    "dev": {
      "cache": false,
      "persistent": true,
      "outputLogs": "full",
      "env": [
        "NEXT_PUBLIC_API_URL",
        "NEXT_PUBLIC_CORS_ORIGIN",
        "NEXT_PUBLIC_ALLOWED_ORIGIN",
        "NEXT_PUBLIC_WEB_URL",
        "NEXT_PUBLIC_DASHBOARD_URL",
        "NEXT_PUBLIC_STORE_DOMAIN",
        "NEXT_PUBLIC_NODE_ENV"
      ]
    },
    "db:push": {
      "cache": false
    },
    "db:studio": {
      "cache": false,
      "persistent": true
    },
    "db:migrate": {
      "cache": false
    },
    "db:generate": {
      "cache": false
    },
    "db:seed": {
      "cache": false
    },
    "db:reset-and-seed": {
      "cache": false
    },
    "db:reset": {
      "cache": false,
      "persistent": true
    },
    "db:format": {
      "cache": false,
      "persistent": true
    },
    "i18n:types": {
      "dependsOn": [
        "@dukkani/i18n#dashboard:types",
        "@dukkani/i18n#web:types",
        "@dukkani/i18n#storefront:types",
        "@dukkani/i18n#ui:types"
      ]
    },
    "i18n:status": {
      "dependsOn": [
        "@dukkani/i18n#dashboard:status",
        "@dukkani/i18n#web:status",
        "@dukkani/i18n#storefront:status",
        "@dukkani/i18n#ui:status"
      ]
    },
    "@dukkani/i18n#dashboard:types": {
      "dependsOn": ["^@dukkani/i18n#ui:types"],
      "inputs": ["src/apps/dashboard/**"]
    },
    "@dukkani/i18n#dashboard:status": {
      "dependsOn": ["^@dukkani/i18n#ui:status"],
      "inputs": ["src/apps/dashboard/**", "$TURBO_ROOT$/apps/dashboard/src/**"]
    },
    "@dukkani/i18n#web:types": {
      "dependsOn": ["^@dukkani/i18n#ui:types"],
      "inputs": ["src/apps/web/**"]
    },
    "@dukkani/i18n#web:status": {
      "dependsOn": ["^@dukkani/i18n#ui:status"],
      "inputs": ["src/apps/web/**", "$TURBO_ROOT$/apps/web/src/**"]
    },
    "@dukkani/i18n#storefront:types": {
      "dependsOn": ["^@dukkani/i18n#ui:types"],
      "inputs": ["src/apps/storefront/**"]
    },
    "@dukkani/i18n#storefront:status": {
      "dependsOn": ["^@dukkani/i18n#ui:status"],
      "inputs": [
        "src/apps/storefront/**",
        "$TURBO_ROOT$/apps/storefront/src/**"
      ]
    },
    "@dukkani/i18n#ui:types": {
      "inputs": ["src/shared/locales/fr/ui.json"]
    },
    "@dukkani/i18n#ui:status": {
      "inputs": [
        "src/shared/locales/*/ui.json",
        "src/shared/ui/**",
        "$TURBO_ROOT$/packages/ui/src/**"
      ]
    },
    "clean": {
      "cache": false,
      "persistent": true
    }
  }
}
