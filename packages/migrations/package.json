{
  "name": "@dukkani/migrations",
  "version": "0.1.0",
  "description": "Database and storage migration utilities for Dukkani",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./src/index.ts"
    },
    "./env": {
      "types": "./dist/env.d.ts",
      "default": "./src/env/index.ts"
    },
    "./cli": {
      "types": "./dist/cli/index.d.ts",
      "default": "./src/cli/index.ts"
    },
    "./*": {
      "types": "./dist/*.d.ts",
      "default": "./src/*.ts"
    }
  },
  "bin": {
    "dukkani-migrate": "./dist/cli/index.js"
  },
  "type": "module",
  "scripts": {
    "build": "tsdown",
    "check-types": "tsc --noEmit -p tsconfig.json",
    "check-types:fast": "tsgo --noEmit -p tsconfig.json",
    "clean": "rm -rf dist node_modules",
    "migrate": "tsx src/cli/index.ts",
    "migrate:storage": "tsx src/cli/index.ts storage migrate",
    "migrate:storage:rollback": "tsx src/cli/index.ts storage rollback",
    "migrate:storage:validate": "tsx src/cli/index.ts storage validate",
    "migration:create": "tsx src/scripts/create-migration.ts",
    "migration:create:storage": "tsx src/scripts/create-migration.ts --type storage",
    "migration:create:database": "tsx src/scripts/create-migration.ts --type database"
  },
  "devDependencies": {
    "@dukkani/config": "workspace:*",
    "tsdown": "catalog:"
  },
  "peerDependencies": {
    "typescript": "^6.0.2"
  },
  "dependencies": {
    "@dukkani/common": "workspace:*",
    "@dukkani/db": "workspace:*",
    "@dukkani/env": "workspace:*",
    "@dukkani/logger": "workspace:*",
    "@dukkani/storage": "workspace:*",
    "@dukkani/tracing": "workspace:*",
    "@supabase/supabase-js": "^2.104.0",
    "@t3-oss/env-core": "catalog:",
    "cli-progress": "^3.12.0",
    "commander": "^14.0.3",
    "dotenv": "catalog:",
    "inquirer": "^13.4.2",
    "nanoid": "catalog:"
  }
}
