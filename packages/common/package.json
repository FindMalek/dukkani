{
  "name": "@dukkani/common",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./src/index.ts"
    },
    "./schemas": {
      "types": "./dist/schemas/index.d.ts",
      "default": "./src/schemas/index.ts"
    },
    "./entities": {
      "types": "./dist/entities/index.d.ts",
      "default": "./src/entities/index.ts"
    },
    "./services": {
      "types": "./dist/services/index.d.ts",
      "default": "./src/services/index.ts"
    },
    "./utils": {
      "types": "./dist/utils/index.d.ts",
      "default": "./src/utils/index.ts"
    },
    "./errors": {
      "types": "./dist/errors/index.d.ts",
      "default": "./src/errors/index.ts"
    },
    "./*": {
      "types": "./dist/*.d.ts",
      "default": "./src/*.ts"
    }
  },
  "scripts": {
    "build": "tsdown",
    "clean": "rm -rf dist node_modules",
    "check-types": "tsc --noEmit -p tsconfig.json",
    "check-types:fast": "tsgo --noEmit -p tsconfig.json"
  },
  "peerDependencies": {
    "typescript": "catalog:",
    "next": "catalog:"
  },
  "dependencies": {
    "@dukkani/db": "workspace:*",
    "@dukkani/env": "workspace:*",
    "@dukkani/i18n": "workspace:*",
    "@dukkani/logger": "workspace:*",
    "@dukkani/tracing": "workspace:*",
    "@prisma/client": "catalog:",
    "@formatjs/intl-localematcher": "catalog:",
    "negotiator": "catalog:",
    "nanoid": "catalog:",
    "nuqs": "catalog:",
    "zod": "catalog:",
    "date-fns": "catalog:"
  },
  "devDependencies": {
    "@dukkani/config": "workspace:*",
    "@types/negotiator": "catalog:",
    "tsdown": "catalog:"
  }
}
