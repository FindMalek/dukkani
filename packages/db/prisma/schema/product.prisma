/**
 * Product category scoped to one store.
 * Stable identity only: categories do not version with catalog drafts (unlike ProductVersion).
 */
model Category {
  id String @id @default(cuid())

  name String

  products Product[]

  updatedAt DateTime @updatedAt @map("updated_at")
  createdAt DateTime @default(now()) @map("created_at")

  storeId String @map("store_id")
  store   Store  @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@unique([storeId, name])
  @@index([storeId])
  @@map("categories")
}

/**
 * Logical product: stable id (e.g. storefront URL), store, category, and merchant "listed" flag.
 * Sellable copy (name, price, media, variants) always lives on ProductVersion, not here.
 * `currentPublishedVersionId` / `draftVersionId` point at the live catalog row and the in-progress edit buffer.
 */
model Product {
  id String @id

  published Boolean @default(false)

  type ProductType @default(SIMPLE)

  currentPublishedVersionId String?         @map("current_published_version_id")
  currentPublishedVersion   ProductVersion? @relation("ProductCurrentPublishedVersion", fields: [currentPublishedVersionId], references: [id], onDelete: Restrict)

  draftVersionId String?         @map("draft_version_id")
  draftVersion   ProductVersion? @relation("ProductDraftVersion", fields: [draftVersionId], references: [id], onDelete: SetNull)

  versions ProductVersion[] @relation("ProductVersionsList")

  orderItems         OrderItem[]
  productCollections ProductCollection[]

  bundleChildRefs      BundleItem[]           @relation("BundleChildProduct")
  orderItemBundleRefs  OrderItemBundleChild[]

  updatedAt DateTime @updatedAt @map("updated_at")
  createdAt DateTime @default(now()) @map("created_at")

  storeId String @map("store_id")
  store   Store  @relation(fields: [storeId], references: [id], onDelete: Cascade)

  categoryId String?   @map("category_id")
  category   Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  @@index([categoryId])
  @@index([storeId])
  @@index([storeId, type])
  @@index([currentPublishedVersionId])
  @@index([draftVersionId])
  @@map("products")
}

/**
 * Immutable-in-practice snapshot of what can be sold for a Product at a point in time.
 * Draft = editable workspace; published = live catalog; archived = superseded but kept for order history.
 * `createdFromVersionId` records which version was forked when creating a new draft (optional).
 */
model ProductVersion {
  id String @id @default(cuid())

  productId String  @map("product_id")
  product   Product @relation("ProductVersionsList", fields: [productId], references: [id], onDelete: Cascade)

  status        ProductVersionStatus
  versionNumber Int                  @map("version_number")

  name              String
  description       String?
  price             Decimal @db.Decimal(10, 2)
  stock             Int
  /// Denormalized units for list/filter/sort: equals `stock` when !hasVariants, else sum of variant stocks.
  totalVariantStock Int     @default(0) @map("total_variant_stock")
  hasVariants       Boolean @default(false) @map("has_variants")
  isBundle          Boolean @default(false) @map("is_bundle")

  /// Denormalized min/max effective variant sell prices (variant.price ?? version.price). Null when !hasVariants or no variants.
  variantEffectivePriceMin Decimal? @map("variant_effective_price_min") @db.Decimal(10, 2)
  variantEffectivePriceMax Decimal? @map("variant_effective_price_max") @db.Decimal(10, 2)

  createdFromVersionId String?          @map("created_from_version_id")
  createdFromVersion   ProductVersion?  @relation("VersionFork", fields: [createdFromVersionId], references: [id], onDelete: SetNull)
  forkedChildren       ProductVersion[] @relation("VersionFork")

  images         Image[]
  variantOptions ProductVariantOption[]
  variants       ProductVariant[]
  addonGroups    ProductAddonGroup[]

  productsAsCurrentPublished Product[] @relation("ProductCurrentPublishedVersion")
  productsAsDraft            Product[] @relation("ProductDraftVersion")

  orderItems           OrderItem[]
  bundleItems          BundleItem[]           @relation("BundleVersionItems")
  orderItemBundleRefs  OrderItemBundleChild[]

  updatedAt DateTime @updatedAt @map("updated_at")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([productId])
  @@index([productId, status])
  @@index([productId, versionNumber])
  @@map("product_versions")
}

/**
 * Image row for one product version; URLs belong to the sellable snapshot, not the logical Product alone.
 */
model Image {
  id  String @id @default(cuid())
  url String

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  productVersionId String         @map("product_version_id")
  productVersion   ProductVersion @relation(fields: [productVersionId], references: [id], onDelete: Cascade)

  variantImages ProductVariant[] @relation("VariantImage")

  @@index([productVersionId])
  @@map("images")
}

/**
 * Named variant option (e.g. Size) and its allowed values for this ProductVersion.
 * Unique per version by option name.
 */
model ProductVariantOption {
  id String @id @default(cuid())

  name String

  values            ProductVariantOptionValue[]
  variantSelections ProductVariantSelection[]

  updatedAt DateTime @updatedAt @map("updated_at")
  createdAt DateTime @default(now()) @map("created_at")

  productVersionId String         @map("product_version_id")
  productVersion   ProductVersion @relation(fields: [productVersionId], references: [id], onDelete: Cascade)

  @@unique([productVersionId, name])
  @@index([productVersionId])
  @@map("product_variant_options")
}

/**
 * One allowed value for a ProductVariantOption (e.g. "M" under Size).
 */
model ProductVariantOptionValue {
  id String @id @default(cuid())

  value String

  selections ProductVariantSelection[]

  updatedAt DateTime @updatedAt @map("updated_at")
  createdAt DateTime @default(now()) @map("created_at")

  optionId String               @map("option_id")
  option   ProductVariantOption @relation(fields: [optionId], references: [id], onDelete: Cascade)

  @@unique([optionId, value])
  @@index([optionId])
  @@map("product_variant_option_values")
}

/**
 * Concrete SKU row under one ProductVersion: stock and optional per-variant price override.
 * Unique (productVersionId, sku) when sku is used.
 */
model ProductVariant {
  id String @id @default(cuid())

  sku        String?
  price      Decimal? @db.Decimal(10, 2)
  stock      Int
  trackStock Boolean  @default(true) @map("track_stock")

  imageId String? @map("image_id")
  image   Image?  @relation("VariantImage", fields: [imageId], references: [id], onDelete: SetNull)

  orderItems          OrderItem[]
  selections          ProductVariantSelection[]
  bundleChildRefs     BundleItem[]           @relation("BundleChildVariant")
  orderItemBundleRefs OrderItemBundleChild[]

  updatedAt DateTime @default(now()) @map("updated_at")
  createdAt DateTime @default(now()) @map("created_at")

  productVersionId String         @map("product_version_id")
  productVersion   ProductVersion @relation(fields: [productVersionId], references: [id], onDelete: Cascade)

  @@unique([productVersionId, sku])
  @@index([productVersionId])
  @@index([sku])
  @@index([imageId])
  @@map("product_variants")
}

/**
 * Links a ProductVariant to one chosen value per option dimension (variant ↔ option ↔ value).
 */
model ProductVariantSelection {
  id String @id @default(cuid())

  variantId String @map("variant_id")
  optionId  String @map("option_id")
  valueId   String @map("value_id")

  variant ProductVariant            @relation(fields: [variantId], references: [id], onDelete: Cascade)
  option  ProductVariantOption      @relation(fields: [optionId], references: [id], onDelete: Cascade)
  value   ProductVariantOptionValue @relation(fields: [valueId], references: [id], onDelete: Cascade)

  @@unique([variantId, optionId])
  @@index([variantId])
  @@index([optionId])
  @@index([valueId])
  @@map("product_variant_selections")
}

/**
 * Optional extras for a product version (e.g. hooks). Not part of the variant matrix.
 * Groups control single vs multi select and whether a choice is required.
 */
model ProductAddonGroup {
  id String @id @default(cuid())

  name          String
  sortOrder     Int                       @default(0) @map("sort_order")
  selectionType ProductAddonSelectionType @map("selection_type")
  required      Boolean                   @default(false)

  options ProductAddonOption[]

  updatedAt DateTime @updatedAt @map("updated_at")
  createdAt DateTime @default(now()) @map("created_at")

  productVersionId String         @map("product_version_id")
  productVersion   ProductVersion @relation(fields: [productVersionId], references: [id], onDelete: Cascade)

  @@index([productVersionId])
  @@map("product_addon_groups")
}

/**
 * One selectable add-on (price delta + stock in canonical units for that option).
 */
model ProductAddonOption {
  id String @id @default(cuid())

  name       String
  sortOrder  Int     @default(0) @map("sort_order")
  priceDelta Decimal @map("price_delta") @db.Decimal(10, 2)
  stock      Int     @default(0)

  groupId String            @map("group_id")
  group   ProductAddonGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)

  orderItemAddons OrderItemAddon[]

  updatedAt DateTime @updatedAt @map("updated_at")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([groupId])
  @@map("product_addon_options")
}

/**
 * One child-product slot inside a bundle version.
 * itemQty = how many units of the child are consumed per bundle unit.
 * NULL uniqueness for childVariantId is enforced at the service layer, not the DB,
 * because Postgres treats NULL != NULL in unique indexes.
 */
model BundleItem {
  id        String @id @default(cuid())
  itemQty   Int    @default(1) @map("item_qty")
  sortOrder Int    @default(0) @map("sort_order")

  bundleVersionId String         @map("bundle_version_id")
  bundleVersion   ProductVersion @relation("BundleVersionItems", fields: [bundleVersionId], references: [id], onDelete: Cascade)

  childProductId String  @map("child_product_id")
  childProduct   Product @relation("BundleChildProduct", fields: [childProductId], references: [id], onDelete: Restrict)

  childVariantId String?         @map("child_variant_id")
  childVariant   ProductVariant? @relation("BundleChildVariant", fields: [childVariantId], references: [id], onDelete: Restrict)

  updatedAt DateTime @updatedAt @map("updated_at")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([bundleVersionId])
  @@index([childProductId])
  @@index([childVariantId])
  @@map("bundle_items")
}
