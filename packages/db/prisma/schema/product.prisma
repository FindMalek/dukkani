/**
 * Product category scoped to one store.
 * Stable identity only: categories do not version with catalog drafts (unlike ProductVersion).
 */
model Category {
  id String @id @default(cuid())

  name String

  products Product[]

  updatedAt DateTime @updatedAt @map("updated_at")
  createdAt DateTime @default(now()) @map("created_at")

  storeId String @map("store_id")
  store   Store  @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@unique([storeId, name])
  @@index([storeId])
  @@map("categories")
}

/**
 * Logical product: stable id (e.g. storefront URL), store, category, and merchant "listed" flag.
 * Sellable copy (name, price, media, variants) always lives on ProductVersion, not here.
 * `currentPublishedVersionId` / `draftVersionId` point at the live catalog row and the in-progress edit buffer.
 */
model Product {
  id String @id

  published Boolean @default(false)

  currentPublishedVersionId String?         @map("current_published_version_id")
  currentPublishedVersion   ProductVersion? @relation("ProductCurrentPublishedVersion", fields: [currentPublishedVersionId], references: [id], onDelete: Restrict)

  draftVersionId String?         @map("draft_version_id")
  draftVersion   ProductVersion? @relation("ProductDraftVersion", fields: [draftVersionId], references: [id], onDelete: SetNull)

  versions ProductVersion[] @relation("ProductVersionsList")

  orderItems         OrderItem[]
  productCollections ProductCollection[]

  updatedAt DateTime @updatedAt @map("updated_at")
  createdAt DateTime @default(now()) @map("created_at")

  storeId String @map("store_id")
  store   Store  @relation(fields: [storeId], references: [id], onDelete: Cascade)

  categoryId String?   @map("category_id")
  category   Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  @@index([categoryId])
  @@index([storeId])
  @@index([currentPublishedVersionId])
  @@index([draftVersionId])
  @@map("products")
}

/**
 * Immutable-in-practice snapshot of what can be sold for a Product at a point in time.
 * Draft = editable workspace; published = live catalog; archived = superseded but kept for order history.
 * `createdFromVersionId` records which version was forked when creating a new draft (optional).
 */
model ProductVersion {
  id String @id @default(cuid())

  productId String  @map("product_id")
  product   Product @relation("ProductVersionsList", fields: [productId], references: [id], onDelete: Cascade)

  status        ProductVersionStatus
  versionNumber Int                  @map("version_number")

  name        String
  description String?
  price       Decimal @db.Decimal(10, 2)
  stock       Int
  hasVariants Boolean @default(false) @map("has_variants")

  createdFromVersionId String?          @map("created_from_version_id")
  createdFromVersion   ProductVersion?  @relation("VersionFork", fields: [createdFromVersionId], references: [id], onDelete: SetNull)
  forkedChildren       ProductVersion[] @relation("VersionFork")

  images         Image[]
  variantOptions ProductVariantOption[]
  variants       ProductVariant[]

  productsAsCurrentPublished Product[] @relation("ProductCurrentPublishedVersion")
  productsAsDraft            Product[] @relation("ProductDraftVersion")

  orderItems OrderItem[]

  updatedAt DateTime @updatedAt @map("updated_at")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([productId])
  @@index([productId, status])
  @@index([productId, versionNumber])
  @@map("product_versions")
}

/**
 * Image row for one product version; URLs belong to the sellable snapshot, not the logical Product alone.
 */
model Image {
  id  String @id @default(cuid())
  url String

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  productVersionId String         @map("product_version_id")
  productVersion   ProductVersion @relation(fields: [productVersionId], references: [id], onDelete: Cascade)

  @@index([productVersionId])
  @@map("images")
}

/**
 * Named variant option (e.g. Size) and its allowed values for this ProductVersion.
 * Unique per version by option name.
 */
model ProductVariantOption {
  id String @id @default(cuid())

  name String

  values            ProductVariantOptionValue[]
  variantSelections ProductVariantSelection[]

  updatedAt DateTime @updatedAt @map("updated_at")
  createdAt DateTime @default(now()) @map("created_at")

  productVersionId String         @map("product_version_id")
  productVersion   ProductVersion @relation(fields: [productVersionId], references: [id], onDelete: Cascade)

  @@unique([productVersionId, name])
  @@index([productVersionId])
  @@map("product_variant_options")
}

/**
 * One allowed value for a ProductVariantOption (e.g. "M" under Size).
 */
model ProductVariantOptionValue {
  id String @id @default(cuid())

  value String

  selections ProductVariantSelection[]

  updatedAt DateTime @updatedAt @map("updated_at")
  createdAt DateTime @default(now()) @map("created_at")

  optionId String               @map("option_id")
  option   ProductVariantOption @relation(fields: [optionId], references: [id], onDelete: Cascade)

  @@unique([optionId, value])
  @@index([optionId])
  @@map("product_variant_option_values")
}

/**
 * Concrete SKU row under one ProductVersion: stock and optional per-variant price override.
 * Unique (productVersionId, sku) when sku is used.
 */
model ProductVariant {
  id String @id @default(cuid())

  sku   String?
  price Decimal? @db.Decimal(10, 2)
  stock Int

  orderItems OrderItem[]
  selections ProductVariantSelection[]

  updatedAt DateTime @updatedAt @map("updated_at")
  createdAt DateTime @default(now()) @map("created_at")

  productVersionId String         @map("product_version_id")
  productVersion   ProductVersion @relation(fields: [productVersionId], references: [id], onDelete: Cascade)

  @@unique([productVersionId, sku])
  @@index([productVersionId])
  @@index([sku])
  @@map("product_variants")
}

/**
 * Links a ProductVariant to one chosen value per option dimension (variant ↔ option ↔ value).
 */
model ProductVariantSelection {
  id String @id @default(cuid())

  variantId String @map("variant_id")
  optionId  String @map("option_id")
  valueId   String @map("value_id")

  variant ProductVariant            @relation(fields: [variantId], references: [id], onDelete: Cascade)
  option  ProductVariantOption      @relation(fields: [optionId], references: [id], onDelete: Cascade)
  value   ProductVariantOptionValue @relation(fields: [valueId], references: [id], onDelete: Cascade)

  @@unique([variantId, optionId])
  @@index([variantId])
  @@index([optionId])
  @@index([valueId])
  @@map("product_variant_selections")
}
