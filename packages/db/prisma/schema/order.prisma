/**
 * Customer order header: status, payment, store, customer, address.
 * Line items carry frozen product, version, and variant references.
 */
model Order {
  id String @id

  status OrderStatus

  paymentMethod PaymentMethod @default(COD) @map("payment_method")

  isWhatsApp Boolean @default(false) @map("is_whatsapp")

  notes String?

  orderItems       OrderItem[]
  whatsappMessages WhatsAppMessage[]

  updatedAt DateTime @updatedAt @map("updated_at")
  createdAt DateTime @default(now()) @map("created_at")

  storeId String @map("store_id")
  store   Store  @relation(fields: [storeId], references: [id], onDelete: Cascade)

  customerId String   @map("customer_id")
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Restrict)

  addressId String?  @map("address_id")
  address   Address? @relation(fields: [addressId], references: [id], onDelete: SetNull)

  @@map("orders")
}

/**
 * One purchased line: logical productId, frozen productVersionId (catalog snapshot at checkout),
 * optional productVariantId, unit price and quantity.
 * displayAttributes hold human-readable option labels at order time (no JSON).
 */
model OrderItem {
  id String @id @default(cuid())

  orderId   String @map("order_id")
  productId String @map("product_id")

  productVersionId String         @map("product_version_id")
  productVersion   ProductVersion @relation(fields: [productVersionId], references: [id], onDelete: Restrict)

  quantity Int
  price    Decimal @db.Decimal(10, 2)

  updatedAt DateTime @updatedAt @map("updated_at")
  createdAt DateTime @default(now()) @map("created_at")

  order             Order                       @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product           Product                     @relation(fields: [productId], references: [id], onDelete: Cascade)
  productVariant    ProductVariant?             @relation(fields: [productVariantId], references: [id])
  productVariantId  String?                     @map("product_variant_id")
  displayAttributes OrderItemVariantAttribute[]
  addonSelections   OrderItemAddon[]

  @@index([productVersionId])
  @@map("order_items")
}

/**
 * Frozen add-on lines at checkout (snapshots + optional FK for analytics).
 */
model OrderItemAddon {
  id String @id @default(cuid())

  orderItemId String    @map("order_item_id")
  orderItem   OrderItem @relation(fields: [orderItemId], references: [id], onDelete: Cascade)

  addonOptionId String?             @map("addon_option_id")
  addonOption   ProductAddonOption? @relation(fields: [addonOptionId], references: [id], onDelete: SetNull)

  groupNameSnapshot  String  @map("group_name_snapshot")
  optionNameSnapshot String  @map("option_name_snapshot")
  priceDeltaSnapshot Decimal @map("price_delta_snapshot") @db.Decimal(10, 2)
  quantity           Int     @default(1)

  createdAt DateTime @default(now()) @map("created_at")

  @@index([orderItemId])
  @@index([addonOptionId])
  @@map("order_item_addons")
}

/**
 * Frozen option name + value per order line; written at checkout so receipts stay stable if catalog option names change.
 */
model OrderItemVariantAttribute {
  id String @id @default(cuid())

  orderItemId String    @map("order_item_id")
  orderItem   OrderItem @relation(fields: [orderItemId], references: [id], onDelete: Cascade)

  position   Int
  optionName String @map("option_name")
  value      String

  createdAt DateTime @default(now()) @map("created_at")

  @@index([orderItemId])
  @@map("order_item_variant_attributes")
}
