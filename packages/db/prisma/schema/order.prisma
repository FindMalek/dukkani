/// Customer order header; line items carry frozen product/version/variant references.
model Order {
  id String @id

  status OrderStatus

  paymentMethod PaymentMethod @default(COD) @map("payment_method")

  isWhatsApp Boolean @default(false) @map("is_whatsapp")

  notes String?

  orderItems       OrderItem[]
  whatsappMessages WhatsAppMessage[]

  updatedAt DateTime @updatedAt @map("updated_at")
  createdAt DateTime @default(now()) @map("created_at")

  storeId String @map("store_id")
  store   Store  @relation(fields: [storeId], references: [id], onDelete: Cascade)

  customerId String   @map("customer_id")
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Restrict)

  addressId String?  @map("address_id")
  address   Address? @relation(fields: [addressId], references: [id], onDelete: SetNull)

  @@map("orders")
}

/// One purchased line: ties to logical Product, the frozen ProductVersion (title/price context), and optional variant.
model OrderItem {
  id String @id @default(cuid())

  orderId   String @map("order_id")
  /// Logical product id for navigation and relations; catalog text comes from productVersion.
  productId String @map("product_id")

  /// Version snapshot at checkout (name, pricing rules, etc.); must stay even if the live catalog changes.
  productVersionId String         @map("product_version_id")
  productVersion   ProductVersion @relation(fields: [productVersionId], references: [id], onDelete: Restrict)

  quantity Int
  price    Decimal @db.Decimal(10, 2)

  updatedAt DateTime @updatedAt @map("updated_at")
  createdAt DateTime @default(now()) @map("created_at")

  order             Order                       @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product           Product                     @relation(fields: [productId], references: [id], onDelete: Cascade)
  productVariant    ProductVariant?             @relation(fields: [productVariantId], references: [id])
  productVariantId  String?                     @map("product_variant_id")
  /// Human-readable option labels copied at checkout so receipts stay stable if option names change later.
  displayAttributes OrderItemVariantAttribute[]

  @@index([productVersionId])
  @@map("order_items")
}

/// Frozen option name + value strings at order time (no JSON); mirrors selections the customer picked.
model OrderItemVariantAttribute {
  id String @id @default(cuid())

  orderItemId String    @map("order_item_id")
  orderItem   OrderItem @relation(fields: [orderItemId], references: [id], onDelete: Cascade)

  position   Int
  optionName String @map("option_name")
  value      String

  createdAt DateTime @default(now()) @map("created_at")

  @@index([orderItemId])
  @@map("order_item_variant_attributes")
}
